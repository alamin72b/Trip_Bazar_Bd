NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_NAME=TripBazarBD Backend
APP_DESCRIPTION=Backend API for the TripBazarBD travel-offer platform.
APP_VERSION=1.0.0
DATABASE_PATH=tripbazarbd.sqlite
